#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
DEFAULT_ROOT="$PROJECT_ROOT/runtime"

# shellcheck source=hermes-env
. "$SCRIPT_DIR/hermes-env"
hermes_load_standard_env "$DEFAULT_ROOT" "$PROJECT_ROOT"

resolve_project_path() {
  local value="$1"
  if [[ "$value" == "~" ]]; then
    printf '%s\n' "$HOME"
  elif [[ "$value" == "~/"* ]]; then
    printf '%s\n' "$HOME/${value#~/}"
  elif [[ "$value" == /* ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$PROJECT_ROOT/$value"
  fi
}

ROOT="$(resolve_project_path "${HERMES_INSTANCES_ROOT:-$DEFAULT_ROOT}")"
if [[ "$ROOT" != "$DEFAULT_ROOT" ]]; then
  hermes_load_standard_env "$ROOT" "$PROJECT_ROOT"
fi
CONSOLE_DIR="$(resolve_project_path "${HERMES_CONSOLE_DIR:-$PROJECT_ROOT}")"
HOST="${HERMES_CONSOLE_HOST:-127.0.0.1}"
PORT="${HERMES_CONSOLE_PORT:-5180}"

cd "$CONSOLE_DIR"

HERMES_CONSOLE_HOST="$HOST" HERMES_CONSOLE_PORT="$PORT" npm start
