#!/usr/bin/env bash

hermes_env_trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

hermes_load_env_file() {
  local file="$1" line key value
  [[ -f "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(hermes_env_trim "${line%$'\r'}")"
    [[ -z "$line" || "$line" == \#* || "$line" != *=* ]] && continue
    key="$(hermes_env_trim "${line%%=*}")"
    value="$(hermes_env_trim "${line#*=}")"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
    [[ -n "${!key+x}" ]] && continue
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
      value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
      value="${value:1:${#value}-2}"
    fi
    export "$key=$value"
  done < "$file"
}

hermes_load_standard_env() {
  local root="${1:-}"
  local project_root="${2:-}"
  [[ -n "${HERMES_ENV_FILE:-}" ]] && hermes_load_env_file "$HERMES_ENV_FILE"
  [[ -n "${HERMES_DOCKER_ENV_FILE:-}" ]] && hermes_load_env_file "$HERMES_DOCKER_ENV_FILE"
  [[ -n "${HERMES_CONSOLE_ENV_FILE:-}" ]] && hermes_load_env_file "$HERMES_CONSOLE_ENV_FILE"
  [[ -n "$project_root" ]] && hermes_load_env_file "$project_root/.env"
  [[ -n "$root" ]] && hermes_load_env_file "$root/.env"
  [[ -n "$root" ]] && hermes_load_env_file "$root/console/.env"
}
